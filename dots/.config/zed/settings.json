{
  "disable_ai": false,
  "edit_predictions": {
    "provider": "copilot"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "language_models": {
    "ollama": {},
  },
  "theme": {
    "mode": "system",
    "light": "macOS Classic Light",
    "dark": "macOS Classic Dark",
  },
  "ui_font_size": 12,
  "buffer_font_size": 16,
  "base_keymap": "VSCode",
  "agent": {
    "sidebar_side": "left",
    "provider": null,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
}
